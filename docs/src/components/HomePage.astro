---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const base = import.meta.env.BASE_URL;

const GITHUB = 'https://github.com/0ktav/VeltryNora';
const DOWNLOAD = GITHUB + '/releases/latest/download/VeltryNora-Setup.exe';

const featureIcons: Record<string, string> = {
  nginx: `<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
  php: `<path d="M12 3C7 3 3 6.13 3 10c0 1.73.8 3.31 2.1 4.5L4 20l5.5-2c.8.27 1.6.43 2.5.43C17 18.43 21 15.3 21 11.43S17 3 12 3z" stroke="currentColor" stroke-width="1.5" fill="none"/><text x="8" y="14" font-size="7" fill="currentColor" font-family="monospace" font-weight="bold">PHP</text>`,
  mysql: `<ellipse cx="12" cy="6" rx="8" ry="3" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M4 6v6c0 1.66 3.58 3 8 3s8-1.34 8-3V6" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M4 12v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  redis: `<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  sites: `<rect x="3" y="3" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  laravel: `<path d="M12 2L2 12l10 10 10-10L12 2z" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  update: `<path d="M21 2v6h-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8M3 22v-6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>`,
  tools: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  opensource: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  privacy: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  windows: `<rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><rect x="13" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><rect x="3" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/><rect x="13" y="13" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.5" fill="none"/>`,
  active: `<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/><polyline points="12 6 12 12 16 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>`,
};

const changelog = [
  {
    version: 'v1.3.0',
    date: '2026-03-25',
    items: [
      'Sites: change public root directory per site',
      'Parallel downloads: isolated progress per version',
      'Duplicate installs prevented during active download',
      'MySQL active version preserved on parallel install',
      'Fixed: new site modal Enter key leak after cancel',
    ],
  },
  {
    version: 'v1.2.0',
    date: '2026-03-24',
    items: [
      'Auto-update with one-click install',
      'MySQL — databases, users, import/export',
      'MySQL import confirmation modal',
      'Site filter pills by status and PHP version',
      'Installer download progress indicator',
      'Single-instance enforcement (named mutex)',
    ],
  },
  {
    version: 'v1.1.0',
    date: '2026-03-20',
    items: [
      'Hosts file editor',
      'Laravel module per site (artisan, upgrade)',
      'Redis interactive commands panel',
      'Port conflict detector on dashboard',
      'Windows toast notifications for service crashes',
      'Open site in browser with browser preference',
      'Real-time site search and system theme follow',
    ],
  },
  {
    version: 'v1.0.0',
    date: '2026-03-19',
    items: [
      'Initial release',
      'Nginx, PHP, Redis manager with version switching',
      'Virtual sites management',
      'Laravel project creation via Composer',
      'Multilingual interface (RO, EN, RU)',
      'Portable Git, Node.js, Composer',
      'Windows installer (VeltryNora-Setup.exe)',
    ],
  },
];
---

<Layout lang={lang} title={`VeltryNora — ${tr.hero.tagline}`} description={tr.hero.subtitle}>

  <!-- Hero -->
  <section class="relative overflow-hidden pt-20 pb-16 sm:pt-28 sm:pb-24">
    <!-- Background glow -->
    <div class="pointer-events-none absolute inset-0 -top-40 flex items-start justify-center">
      <div class="h-[500px] w-[700px] rounded-full bg-blue-600/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-3 py-1 text-xs text-blue-400 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
        {tr.hero.free}
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-tight">
        VeltryNora
      </h1>
      <p class="mt-5 text-xl sm:text-2xl text-slate-300 font-medium max-w-2xl mx-auto leading-relaxed">
        {tr.hero.tagline}
      </p>
      <p class="mt-4 text-slate-400 max-w-xl mx-auto leading-relaxed">
        {tr.hero.subtitle}
      </p>

      <!-- CTAs -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href={DOWNLOAD}
          class="inline-flex items-center gap-2 rounded-xl bg-blue-600 hover:bg-blue-500 active:bg-blue-700 px-6 py-3 text-sm font-semibold text-white transition-colors shadow-lg shadow-blue-600/25"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          {tr.nav.download} — Windows
        </a>
        <a
          href={GITHUB}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-xl border border-slate-700 hover:border-slate-500 bg-slate-800/50 hover:bg-slate-800 px-6 py-3 text-sm font-semibold text-slate-200 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 0 1 2.53 15.59c-.4.07-.55-.17-.55-.38v-1.98c0-.67-.23-1.1-.49-1.32 1.6-.18 3.28-.78 3.28-3.53 0-.78-.28-1.42-.74-1.92.07-.18.32-.91-.07-1.9 0 0-.6-.19-1.97.74A6.86 6.86 0 0 0 8 4.95a6.86 6.86 0 0 0-1.79.24C4.84 4.17 4.24 4.36 4.24 4.36c-.39.99-.14 1.72-.07 1.9-.46.5-.74 1.14-.74 1.92 0 2.74 1.67 3.35 3.26 3.54-.2.18-.39.5-.46.96-.41.18-1.46.5-2.1-.6 0 0-.38-.69-1.1-.74 0 0-.7-.01-.05.44 0 0 .47.22.8 1.04 0 0 .42 1.28 2.42.85v1.38c0 .21-.14.45-.54.38A8 8 0 0 1 8 0z"/></svg>
          {tr.hero.githubBtn}
        </a>
      </div>

      <!-- Theme comparison slider -->
      <div class="mt-16 mx-auto max-w-5xl select-none">
        <div
          id="theme-slider"
          class="relative rounded-2xl border border-slate-700/60 shadow-2xl shadow-black/60 overflow-hidden cursor-col-resize"
          style="touch-action: none;"
        >
          <!-- Dark screenshot (base) -->
          <img
            src={base + '/screenshots/dashboard-dark.png'}
            alt="VeltryNora dark theme"
            class="block w-full h-auto pointer-events-none"
            draggable="false"
          />
          <!-- Light screenshot (clipped overlay) -->
          <div id="theme-slider-overlay" class="absolute inset-0 overflow-hidden" style="width: 50%;">
            <img
              src={base + '/screenshots/dashboard-light.png'}
              alt="VeltryNora light theme"
              class="block h-full pointer-events-none"
              style="width: 200%; max-width: none;"
              draggable="false"
            />
          </div>
          <!-- Divider -->
          <div id="theme-slider-handle" class="absolute top-0 bottom-0 flex items-center justify-center" style="left: 50%; transform: translateX(-50%);">
            <div class="w-px h-full bg-white/40"></div>
            <div class="absolute flex items-center justify-center w-8 h-8 rounded-full bg-white shadow-lg shadow-black/40">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#334155" stroke-width="2.5" stroke-linecap="round">
                <path d="M9 18l-6-6 6-6"/><path d="M15 6l6 6-6 6"/>
              </svg>
            </div>
          </div>
        </div>
        <p class="mt-3 text-xs text-slate-600 text-center">drag to compare dark / light theme</p>
      </div>

      <script>
        const slider = document.getElementById('theme-slider');
        const overlay = document.getElementById('theme-slider-overlay');
        const handle = document.getElementById('theme-slider-handle');
        let dragging = false;

        function setPosition(clientX: number) {
          const rect = slider!.getBoundingClientRect();
          const pct = Math.min(Math.max((clientX - rect.left) / rect.width, 0.02), 0.98);
          const overlayImg = overlay!.querySelector('img') as HTMLImageElement;
          overlay!.style.width = pct * 100 + '%';
          overlayImg.style.width = (1 / pct) * 100 + '%';
          handle!.style.left = pct * 100 + '%';
        }

        slider!.addEventListener('mousedown', e => { dragging = true; setPosition(e.clientX); });
        window.addEventListener('mousemove', e => { if (dragging) setPosition(e.clientX); });
        window.addEventListener('mouseup', () => { dragging = false; });

        slider!.addEventListener('touchstart', e => { dragging = true; setPosition(e.touches[0].clientX); }, { passive: true });
        window.addEventListener('touchmove', e => { if (dragging) setPosition(e.touches[0].clientX); }, { passive: true });
        window.addEventListener('touchend', () => { dragging = false; });
      </script>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-4">
        {tr.features.title}
      </h2>
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {tr.features.items.map((feature) => (
          <div class="group rounded-xl border border-slate-800 bg-slate-900/50 hover:border-slate-700 hover:bg-slate-900 p-5 transition-all duration-200">
            <div class="mb-3 inline-flex rounded-lg bg-blue-500/10 p-2.5 text-blue-400 group-hover:bg-blue-500/15 transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" set:html={featureIcons[feature.icon]}></svg>
            </div>
            <h3 class="text-sm font-semibold text-white mb-1.5">{feature.name}</h3>
            <p class="text-xs text-slate-400 leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Screenshots gallery -->
  <section class="py-20 sm:py-24 border-t border-slate-800/50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-8" id="gallery-tabs">
        {[
          { key: 'nginx',  label: 'Nginx' },
          { key: 'php',    label: 'PHP' },
          { key: 'redis',  label: 'Redis' },
          { key: 'mysql',  label: 'MySQL' },
          { key: 'sites',  label: 'Sites' },
          { key: 'logs',   label: 'Logs' },
        ].map((tab, i) => (
          <button
            data-tab={tab.key}
            class={[
              'gallery-tab cursor-pointer px-4 py-1.5 rounded-full text-sm font-medium transition-colors border',
              i === 0
                ? 'bg-blue-600 border-blue-600 text-white'
                : 'border-slate-700 text-slate-400 hover:text-slate-200 hover:border-slate-500'
            ].join(' ')}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Screenshot display -->
      <div class="rounded-2xl border border-slate-700/60 shadow-2xl shadow-black/50 overflow-hidden cursor-zoom-in" id="gallery-container">
        {['nginx', 'php', 'redis', 'mysql', 'sites', 'logs'].map((key, i) => (
          <img
            id={`gallery-img-${key}`}
            src={base + `/screenshots/${key}.png`}
            alt={`VeltryNora ${key}`}
            class={['w-full h-auto block', i !== 0 ? 'hidden' : ''].join(' ')}
            draggable="false"
          />
        ))}
      </div>

      <!-- Lightbox -->
      <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 cursor-zoom-out p-4" onclick="this.classList.add('hidden');this.classList.remove('flex');">
        <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full rounded-xl shadow-2xl" draggable="false" />
      </div>
    </div>

    <script>
      const tabs = document.querySelectorAll('.gallery-tab');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const key = (tab as HTMLElement).dataset.tab!;
          tabs.forEach(t => {
            t.classList.remove('bg-blue-600', 'border-blue-600', 'text-white');
            t.classList.add('border-slate-700', 'text-slate-400');
          });
          tab.classList.add('bg-blue-600', 'border-blue-600', 'text-white');
          tab.classList.remove('border-slate-700', 'text-slate-400');
          document.querySelectorAll('[id^="gallery-img-"]').forEach(img => img.classList.add('hidden'));
          document.getElementById('gallery-img-' + key)!.classList.remove('hidden');
        });
      });

      // Lightbox
      document.getElementById('gallery-container')!.addEventListener('click', () => {
        const visible = document.querySelector('[id^="gallery-img-"]:not(.hidden)') as HTMLImageElement;
        if (!visible) return;
        const lb = document.getElementById('lightbox')!;
        (document.getElementById('lightbox-img') as HTMLImageElement).src = visible.src;
        lb.classList.remove('hidden');
        lb.classList.add('flex');
      });

      // Close lightbox on Escape
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
          const lb = document.getElementById('lightbox')!;
          lb.classList.add('hidden');
          lb.classList.remove('flex');
        }
      });
    </script>
  </section>

  <!-- Why -->
  <section id="why" class="py-20 sm:py-24 border-t border-slate-800/50">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-4">
        {tr.why.title}
      </h2>
      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {tr.why.items.map((item) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/30 p-6">
            <div class="mb-4 inline-flex rounded-lg bg-slate-800 p-2.5 text-slate-300">
              <svg width="20" height="20" viewBox="0 0 24 24" set:html={featureIcons[item.icon]}></svg>
            </div>
            <h3 class="text-sm font-semibold text-white mb-2">{item.title}</h3>
            <p class="text-xs text-slate-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Settings pills -->
  <section class="py-20 sm:py-24 border-t border-slate-800/50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">{tr.settings.title}</h2>
      <p class="text-slate-400 mb-12 text-sm">{tr.settings.subtitle}</p>
      <div class="flex flex-wrap justify-center gap-3">
        {tr.settings.items.map(item => (
          <div class="inline-flex items-center gap-2 rounded-xl border border-slate-700/60 bg-slate-900/60 px-4 py-2.5 text-sm text-slate-300 hover:border-slate-600 hover:bg-slate-800/60 transition-colors">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400 shrink-0">
              {item.icon === 'folder'  && <><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></>}
              {item.icon === 'play'    && <><polygon points="5 3 19 12 5 21 5 3"/></>}
              {item.icon === 'stop'    && <><rect x="3" y="3" width="18" height="18" rx="2"/></>}
              {item.icon === 'power'   && <><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></>}
              {item.icon === 'theme'   && <><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></>}
              {item.icon === 'globe'   && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
              {item.icon === 'cpu'     && <><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/></>}
              {item.icon === 'clock'   && <><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></>}
              {item.icon === 'tray'    && <><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></>}
              {item.icon === 'log'     && <><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></>}
              {item.icon === 'browser' && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
              {item.icon === 'bell'    && <><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></>}
              {item.icon === 'alert'   && <><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></>}
            </svg>
            {item.label}
          </div>
        ))}
      </div>

      <!-- Missing CTA -->
      <div class="mt-10 inline-flex items-center gap-2 text-sm text-slate-500">
        <span>{tr.settings.missing}</span>
        <a
          href="https://github.com/0ktav/VeltryNora/issues/new"
          target="_blank"
          rel="noopener"
          class="text-blue-400 hover:text-blue-300 transition-colors font-medium"
        >
          {tr.settings.missingLink}
        </a>
      </div>
    </div>
  </section>

  <!-- Changelog -->
  <section id="changelog" class="py-20 sm:py-24 border-t border-slate-800/50">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-12">
        {tr.changelog.title}
      </h2>
      <div class="space-y-3">
        {changelog.map((release, i) => (
          <details open={i === 0} class="group relative pl-6 border-l border-slate-800">
            <div class="absolute -left-[5px] top-4 w-2.5 h-2.5 rounded-full border-2 border-blue-500 bg-[#080d1a]"></div>
            <summary class="flex items-center gap-3 cursor-pointer list-none py-2 px-3 -ml-3 rounded-lg hover:bg-slate-800/50 transition-colors select-none">
              <svg class="text-slate-500 transition-transform group-open:rotate-90 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
              <span class="text-sm font-bold text-white">{release.version}</span>
              {i === 0 && (
                <span class="rounded-full bg-blue-500/15 px-2 py-0.5 text-xs font-medium text-blue-400">latest</span>
              )}
              <span class="text-xs text-slate-600">{release.date}</span>
              <span class="ml-auto text-xs text-slate-600 group-open:hidden">click for details</span>
            </summary>
            <ul class="mt-3 mb-4 space-y-1.5">
              {release.items.map(item => (
                <li class="flex items-start gap-2 text-xs text-slate-400">
                  <svg class="mt-0.5 shrink-0 text-slate-600" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA bottom -->
  <section class="py-20 border-t border-slate-800/50">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">{tr.hero.tagline}</h2>
      <a
        href={DOWNLOAD}
        class="inline-flex items-center gap-2 rounded-xl bg-blue-600 hover:bg-blue-500 px-8 py-3.5 text-sm font-semibold text-white transition-colors shadow-lg shadow-blue-600/25"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {tr.hero.downloadBtn}
      </a>
      <p class="mt-3 text-xs text-slate-600">{tr.hero.free} · Windows 10/11</p>
    </div>
  </section>

  <Fragment slot="footer-text">{tr.footer.madeWith}</Fragment>

</Layout>
