<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Domain}}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0d0d0f;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: #e2e2e2;
        }

        .card {
            text-align: center;
            padding: 56px 64px;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 16px;
            background: #141417;
            max-width: 480px;
            width: 90%;
        }

        .logo {
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #00d4aa;
            margin-bottom: 32px;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .logo-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #00d4aa;
            display: inline-block;
        }

        h1 {
            font-size: 26px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 10px;
            letter-spacing: -0.02em;
        }

        .domain {
            color: #00d4aa;
        }

        .motto {
            font-size: 13px;
            color: #6b6b7a;
            margin-top: 28px;
            line-height: 1.6;
        }

        .motto em {
            color: #9b9baa;
            font-style: normal;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">
            <span class="logo-dot"></span>
            VeltryNora
        </div>
        <h1>Welcome to <span class="domain">{{.Domain}}</span></h1>
        <p class="motto">
            Your environment is ready. <em>Now go build something great.</em>
        </p>
    </div>
</body>
</html>
